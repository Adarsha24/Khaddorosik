# ──────────────────────────────────────────────────────
#  Khaddorosik POS — Environment Variables
# ──────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/khaddorosik"

# JWT secrets — generate: openssl rand -base64 64
JWT_ACCESS_SECRET="your-access-secret-min-32-chars-change-me"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-change-me"

# ── SMTP (free Gmail SMTP for OTP emails) ─────────────
# Enable: Google Account → Security → App Passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password-16-chars"

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Khaddorosik POS"

# ──────────────────────────────────────────────────────
#  Quick Start
# ──────────────────────────────────────────────────────
# 1. cp .env.example .env  →  fill in all values
# 2. npm install
# 3. npx prisma db push           (apply schema — DEV only)
# 4. npm run db:seed              (creates 10 restaurants)
# 5. npm run dev
#
