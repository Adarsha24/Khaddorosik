# ──────────────────────────────────────────────────────
#  Khaddorosik POS — Environment Variables
# ──────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/khaddorosik"

# JWT secrets — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"

# Tax rate as a decimal (e.g. 0.18 = 18% GST)
TAX_RATE="0.05"

# Next.js
NEXT_PUBLIC_APP_NAME="Khaddorosik POS"

# ──────────────────────────────────────────────────────
#  Setup Steps
# ──────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in values above
# 3. npx prisma migrate dev --name init
# 4. npx prisma db seed
# 5. npm run dev
